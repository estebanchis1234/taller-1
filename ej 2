#include <iostream>
using namespace std;

int main() {
    int A, B;

    cout << "Ingrese A: ";
    cin >> A;

    cout << "Ingrese B: ";
    cin >> B;

    // Intercambio sin variable auxiliar
    A = A + B;
    B = A - B;
    A = A - B;

    cout << "Despues del intercambio:" << endl;
    cout << "A = " << A << endl;
    cout << "B = " << B << endl;

    return 0;
}
